<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#10072F"
    android:padding="28dp"
    tools:context=".MainActivity">

    <!-- Bolha grande superior esquerda -->
    <View
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:background="#3B168C"
        android:alpha="0.35"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="-130dp"
        android:layout_marginStart="-120dp"/>

    <!-- Bolha pequena superior direita -->
    <View
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:background="#6C3BFF"
        android:alpha="0.35"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="120dp"
        android:layout_marginEnd="10dp"/>

    <!-- Bolha grande inferior direita -->
    <View
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:background="#2D1B73"
        android:alpha="0.45"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="-110dp"
        android:layout_marginEnd="-130dp"/>

    <TextView
        android:id="@+id/txtMini"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ORGANIZE • FOQUE • APROVE"
        android:textColor="#B98CFF"
        android:textSize="12sp"
        android:letterSpacing="0.18"
        android:layout_marginTop="72dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="135dp"
        android:layout_height="135dp"
        android:src="@drawable/ic_book_logo"
        app:tint="#FFFFFF"
        android:layout_marginTop="60dp"
        app:layout_constraintTop_toBottomOf="@id/txtMini"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FocusConcursos TI"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="31sp"
        android:layout_marginTop="28dp"
        app:layout_constraintTop_toBottomOf="@id/imgLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txtFrase"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:text="Transforme disciplina em aprovação."
        android:textColor="#D9D3F5"
        android:textSize="17sp"
        android:gravity="center"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/txtTitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ProgressBar
        android:id="@+id/progressSplash"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:indeterminateTint="#9B6DFF"
        android:layout_marginTop="42dp"
        app:layout_constraintTop_toBottomOf="@id/txtFrase"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnEntrar"
        android:layout_width="270dp"
        android:layout_height="60dp"
        android:text="Entrar"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#7B4DFF"
        android:elevation="10dp"
        android:layout_marginBottom="105dp"
        app:cornerRadius="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txtRodape"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Estudos organizados, resultados reais."
        android:textColor="#B8AEDF"
        android:textSize="14sp"
        android:layout_marginBottom="52dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>