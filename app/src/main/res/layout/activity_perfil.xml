<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#10072F">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- TOPO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:background="@drawable/bg_top_dashboard"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="22dp">

            <TextView
                android:id="@+id/btnVoltarPerfil"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:text="←"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:gravity="center"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Meu Perfil"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Resumo do estudante"
                    android:textColor="#E8DDFF"
                    android:textSize="14sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- CARD PERFIL -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="18dp"
            app:cardCornerRadius="26dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#FAFAFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp">

                <TextView
                    android:layout_width="86dp"
                    android:layout_height="86dp"
                    android:gravity="center"
                    android:text="👩‍💻"
                    android:textSize="50sp"
                    android:background="#EDE7FF"/>

                <TextView
                    android:id="@+id/txtNome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clara Beatriz"
                    android:textColor="#1A1145"
                    android:textSize="25sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp"/>

                <TextView
                    android:id="@+id/txtCurso"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ADS - Faculdade Senac"
                    android:textColor="#5A5370"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🟢 Estudante ativo"
                    android:textColor="#2E8B57"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- CARDS DE ESTATÍSTICAS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="95dp"
                android:layout_weight="1"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FAFAFF">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="📚\n3\nMatérias"
                    android:textColor="#1A1145"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:gravity="center"/>
            </androidx.cardview.widget.CardView>

            <Space
                android:layout_width="10dp"
                android:layout_height="1dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="95dp"
                android:layout_weight="1"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FAFAFF">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="🔥\n7\nDias"
                    android:textColor="#1A1145"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:gravity="center"/>
            </androidx.cardview.widget.CardView>

            <Space
                android:layout_width="10dp"
                android:layout_height="1dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="95dp"
                android:layout_weight="1"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FAFAFF">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="⏱\n1h15\nFoco"
                    android:textColor="#1A1145"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:gravity="center"/>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- META DIÁRIA -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="18dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#FAFAFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎯 Meta diária"
                    android:textColor="#1A1145"
                    android:textStyle="bold"
                    android:textSize="18sp"/>

                <TextView
                    android:id="@+id/txtMetaDiaria"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Estudar 2 horas por dia"
                    android:textColor="#5A5370"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"/>

                <ProgressBar
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:max="100"
                    android:progress="75"
                    android:progressTint="#7B4DFF"
                    android:layout_marginTop="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="75% da meta concluída"
                    android:textColor="#5A5370"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- CONFIGURAÇÕES -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#EDE7FF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚙️ Configurações"
                    android:textColor="#1A1145"
                    android:textStyle="bold"
                    android:textSize="18sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✏️ Alterar nome e curso"
                    android:textColor="#5A5370"
                    android:textSize="14sp"
                    android:layout_marginTop="10dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌙 Tema escuro ativado"
                    android:textColor="#5A5370"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- BOTÃO EDITAR -->
        <Button
            android:id="@+id/btnEditarPerfil"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_margin="18dp"
            android:text="Editar Perfil"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#7B4DFF"/>

    </LinearLayout>
</ScrollView>