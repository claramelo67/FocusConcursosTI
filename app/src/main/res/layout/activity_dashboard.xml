<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#10072F"
    tools:context=".DashboardActivity">

    <!-- TOPO DA DASHBOARD -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="165dp"
            android:background="@drawable/bg_top_dashboard"
            android:orientation="horizontal"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Olá, estudante!"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bons estudos hoje!"
                    android:textColor="#E8DDFF"
                    android:textSize="15sp"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_book_logo"
                app:tint="#FFFFFF"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- CONTEÚDO PRINCIPAL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- TÍTULO DA SEÇÃO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resumo dos estudos"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- CARDS DE RESUMO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- CARD MATÉRIAS -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardMaterias"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="#FAFAFF">

                    <TextView
                        android:id="@+id/txtMaterias"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="📚\n5\nMatérias"
                        android:textColor="#1A1145"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center" />
                </androidx.cardview.widget.CardView>

                <Space
                    android:layout_width="10dp"
                    android:layout_height="1dp" />

                <!-- CARD METAS -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardMetas"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="#FAFAFF">

                    <TextView
                        android:id="@+id/txtMetas"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="🎯\n12\nMetas"
                        android:textColor="#1A1145"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center" />
                </androidx.cardview.widget.CardView>

                <Space
                    android:layout_width="10dp"
                    android:layout_height="1dp" />

                <!-- CARD FOCO -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="#FAFAFF">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="⏱\n18h\nFoco"
                        android:textColor="#1A1145"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center" />
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- CARD DE PROGRESSO DAS MATÉRIAS -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FAFAFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Progresso das matérias"
                        android:textColor="#1A1145"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lógica de Programação — 75%"
                        android:textColor="#30284D"
                        android:layout_marginTop="16dp" />

                    <ProgressBar
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:progress="75"
                        android:max="100"
                        android:progressTint="#7B4DFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Banco de Dados — 60%"
                        android:textColor="#30284D"
                        android:layout_marginTop="14dp" />

                    <ProgressBar
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:progress="60"
                        android:max="100"
                        android:progressTint="#7B4DFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Redes de Computadores — 45%"
                        android:textColor="#30284D"
                        android:layout_marginTop="14dp" />

                    <ProgressBar
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:progress="45"
                        android:max="100"
                        android:progressTint="#7B4DFF" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD DE LEMBRETE -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardLembrete"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FAFAFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔔"
                        android:textSize="30sp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lembrete"
                            android:textColor="#1A1145"
                            android:textSize="17sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/txtLembrete"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Simulado de Redes amanhã às 19h"
                            android:textColor="#5A5370"
                            android:textSize="14sp"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- GRÁFICO DE DESEMPENHO SEMANAL -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FAFAFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Desempenho semanal"
                        android:textColor="#1A1145"
                        android:textSize="17sp"
                        android:textStyle="bold"/>

                    <!-- BARRAS DO GRÁFICO -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:orientation="horizontal"
                        android:gravity="bottom|center"
                        android:layout_marginTop="18dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="bottom|center"
                            android:orientation="vertical">

                            <View
                                android:layout_width="38dp"
                                android:layout_height="90dp"
                                android:background="#7B4DFF"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SEG"
                                android:textSize="11sp"
                                android:textColor="#5A5370"
                                android:layout_marginTop="8dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="bottom|center"
                            android:orientation="vertical">

                            <View
                                android:layout_width="38dp"
                                android:layout_height="140dp"
                                android:background="#5B35C9"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TER"
                                android:textSize="11sp"
                                android:textColor="#5A5370"
                                android:layout_marginTop="8dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="bottom|center"
                            android:orientation="vertical">

                            <View
                                android:layout_width="38dp"
                                android:layout_height="120dp"
                                android:background="#8E67FF"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="QUA"
                                android:textSize="11sp"
                                android:textColor="#5A5370"
                                android:layout_marginTop="8dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="bottom|center"
                            android:orientation="vertical">

                            <View
                                android:layout_width="38dp"
                                android:layout_height="160dp"
                                android:background="#41228F"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="QUI"
                                android:textSize="11sp"
                                android:textColor="#5A5370"
                                android:layout_marginTop="8dp"/>
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
